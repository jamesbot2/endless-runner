[Unit]
Description=Endless Runner Account Server (API + auth)
After=network.target

[Service]
ExecStart=/usr/bin/node /home/ejimm363/.openclaw/workspace/subway-surfer/server/account-server.js
WorkingDirectory=/home/ejimm363/.openclaw/workspace/subway-surfer/server
Restart=always
RestartSec=5
